# 阿里云DashScope API密钥（通义千问+通义万相）
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# 代理配置（如果需要）
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897

# 工作流配置
MAX_ITERATIONS=5
CI_THRESHOLD=28
GAMMA=0.8
DELTA=0.3
L_MAX=100

# 图像生成配置
IMAGE_GENERATION_COUNT=5  # 每次生成k张图
IMAGE_SIZE=1024x1024
IMAGE_QUALITY=high
